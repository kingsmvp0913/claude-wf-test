<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_margin" model="ir.ui.view">
        <field name="name">sale.order.margin.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='tax_totals']" position="before">
                <field name="gross_margin_total" readonly="1"/>
                <field name="margin_rate" widget="percentage" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_order_tree_margin" model="ir.ui.view">
        <field name="name">sale.order.margin.tree</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_total']" position="after">
                <field name="margin_rate" widget="percentage" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
