<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_quotation_tree_stats" model="ir.ui.view">
        <field name="name">sale.order.quotation.stats.tree</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_quotation_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="js_class">sale_quotation_stats_list</attribute>
            </xpath>
        </field>
    </record>

    <record id="action_quotation_stats_dashboard" model="ir.actions.client">
        <field name="name">報價單統計報表</field>
        <field name="tag">idx_sale_stats.quotation_stats_dashboard</field>
        <field name="target">current</field>
    </record>
</odoo>
